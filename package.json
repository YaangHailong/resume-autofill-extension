{
  "name": "resume-autofill-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome MV3 extension for preview-first resume autofill.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/build-content.cjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "tsc -p tsconfig.test.json && node .test-dist/tests/run-unit.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "1.3.2",
    "vite": "2.9.16",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "1.34.3",
    "@types/chrome": "0.0.246",
    "@types/jsdom": "20.0.1",
    "@types/node": "14.18.63",
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.11",
    "jsdom": "20.0.3",
    "typescript": "4.9.5"
  }
}
